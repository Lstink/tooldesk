{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "desktool",
  "version": "1.2.0",
  "identifier": "com.lstink.desktool",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "图片转 PDF",
        "width": 900,
        "height": 700,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    },
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZCNzNDQjE4RTExODdGNkMKUldSc2Z4amhHTXR6KzhYeWZETHNNZExWd2lXd3JBRFIwTFZ3R2lSb1QxZHByM1FrYzdNZmdqMksK",
      "endpoints": [
        "https://github.com/Lstink/tooldesk/releases/latest/download/latest.json"
      ]
    }
  }
}
